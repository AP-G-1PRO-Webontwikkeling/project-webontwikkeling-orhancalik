<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Club Details</title>
  </head>
  <body>
<%-include('header') %>
<%-include('navbar') %>
<div class="club-detail-container">
  <div class="club-detail-header">
      <img src="<%= club.logo %>" alt="<%= club.name %> Logo" class="w-40 h-40 object-cover rounded-full">
      <h1 class="text-3xl font-bold mt-4 mb-2"><%= club.name %></h1>
      <p class="text-gray-600 mb-4"><%= club.description %></p>
  </div>
  <div class="club-detail-info">
      <h2 class="text-xl font-bold mb-2">Opgericht:</h2>
      <p><%= club.founded %></p>
      <h2 class="text-xl font-bold mt-4 mb-2">Stadion:</h2>
      <p><%= club.stadium %></p>
      <h2 class="text-xl font-bold mt-4 mb-2">Plaats:</h2>
      <p><%= club.location %></p>
      <h2 class="text-xl font-bold mt-4 mb-2">Website:</h2>
      <p><a href="<%= club.website %>" target="_blank" class="text-blue-500 hover:underline"><%= club.website %></a></p>
  </div>
</div>
<%-include('footer') %>
</body>
</html>